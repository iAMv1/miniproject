{
  "name": "mindpulse-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-http://localhost:5000/api/v1} NEXTAUTH_SECRET=${NEXTAUTH_SECRET:-mindpulse-nextauth-dev-secret} next build",
    "start": "next start",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start\"",
    "start:backend": "cd ../backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 5000",
    "test": "cd ../backend && python -m pytest",
    "test:integration": "if [ -f ../backend/test_endpoints.py ]; then python ../backend/test_endpoints.py; else echo \"No integration test script found\"; fi",
    "test:live": "if [ -f ../backend/test_live.py ]; then python ../backend/test_live.py; else echo \"No e2e/live test script found\"; fi",
    "lint": "next lint"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "@supabase/supabase-js": "^2.103.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "onnxruntime-web": "^1.24.3",
    "partysocket": "^1.1.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-gauge-component": "^2.0.28",
    "recharts": "^2.15.4",
    "uplot": "^1.6.32",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
